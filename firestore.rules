rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.uid == 'WrNiMMdeVZTNtxZPNa102qZGI8y1';
    }

    function authorNotChanged() {
      return request.resource.data.authorId == resource.data.authorId;
    }

    match /posts/{postId} {
      allow read: if true;
      allow create: if isSignedIn()
                    && request.resource.data.authorId == request.auth.uid;
      allow update: if isOwner(resource.data.authorId) && authorNotChanged();
      allow delete: if isOwner(resource.data.authorId) || isAdmin();
    }

    match /simple-posts/{postId} {
      allow read: if true;
      allow create: if isSignedIn()
                    && request.resource.data.authorId == request.auth.uid;
      allow update: if isOwner(resource.data.authorId) && authorNotChanged();
      allow delete: if isOwner(resource.data.authorId) || isAdmin();
    }

    match /simple-travels/{docId} {
      allow read: if true;
      allow create: if isSignedIn()
                    && request.resource.data.authorId == request.auth.uid;
      allow update: if isOwner(resource.data.authorId) && authorNotChanged();
      allow delete: if isOwner(resource.data.authorId) || isAdmin();
    }

    match /spots/{spotId} {
      allow read: if true;
      allow create: if isSignedIn()
                    && request.resource.data.authorId == request.auth.uid;
      allow update: if isOwner(resource.data.authorId) && authorNotChanged();
      allow delete: if isOwner(resource.data.authorId) || isAdmin();
    }

    match /users/{userId} {
      allow read: if true;
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId) || isAdmin();

      match /likes/{postId} {
        allow read, write: if isOwner(userId);
      }

      match /bookmarks/{postId} {
        allow read, write: if isOwner(userId);
      }

      match /thanks/{postId} {
        allow read, write: if isOwner(userId);
      }

      match /wc2026SquadPredictions/{countrySlug} {
        allow read, write: if isOwner(userId);
      }
    }

    match /banners/{bannerId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /wc2026PublicSquadPredictions/{docId} {
      allow read: if true;
      allow create, update: if isSignedIn()
                            && docId.split('_').size() == 2
                            && docId.split('_')[1] == request.auth.uid;
      allow delete: if isAdmin();
    }

    match /wc2026PredictionShares/{shareId} {
      allow read: if true;
      allow create: if isSignedIn()
                    && request.resource.data.createdByUid == request.auth.uid;
      allow update: if isSignedIn()
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['commentCount']);
      allow delete: if (isSignedIn() && resource.data.createdByUid == request.auth.uid) || isAdmin();

      match /comments/{commentId} {
        allow read: if true;
        allow create: if isSignedIn()
                      && request.resource.data.createdByUid == request.auth.uid;
        allow update: if false;
        allow delete: if (isSignedIn() && resource.data.createdByUid == request.auth.uid) || isAdmin();
      }
    }

    match /plFinalTablePredictionShares/{shareId} {
      allow read: if true;
      allow create: if (request.resource.data.keys().hasOnly(['schemaVersion', 'eventId', 'snapshotJson', 'createdAt'])
                      || request.resource.data.keys().hasOnly(['schemaVersion', 'eventId', 'snapshotJson']))
                    && request.resource.data.schemaVersion == 1
                    && request.resource.data.eventId == 'premier-league-final-table'
                    && request.resource.data.snapshotJson is string
                    && request.resource.data.snapshotJson.size() <= 10000;
      allow update: if false;
      allow delete: if isAdmin();
    }

    match /wc2026Schedule/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
